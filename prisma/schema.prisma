generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PARTICIPANT
  VOLUNTEER
  JUDGE
  ADMIN
}

enum TeamStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JudgeAssignmentStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

model User {
  id              String            @id @default(cuid())
  name            String
  email           String            @unique
  emailVerified   Boolean           @default(false)
  image           String?
  phone           String?
  password        String?
  role            Role              @default(PARTICIPANT)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  teamMembers     TeamMember[]
  judgeAssignments JudgeAssignment[]
  volunteerZones  VolunteerZone[]
  sessions        Session[]
  accounts        Account[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model Team {
  id              String        @id @default(cuid())
  name            String        @unique
  prototypeTitle  String
  description     String
  category        String
  requirements    String?
  stallNumber     Int?          @unique
  status          TeamStatus    @default(PENDING)
  qrCode          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  members         TeamMember[]
  judgeAssignments JudgeAssignment[]
  stallLocation   StallLocation?
}

model TeamMember {
  id         String @id @default(cuid())
  teamId     String
  userId     String
  roleInTeam String @default("member")
  team       Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Event {
  id             String   @id @default(cuid())
  name           String
  date           DateTime
  venue          String
  description    String?
  scheduleConfig Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model JudgeAssignment {
  id            String                 @id @default(cuid())
  judgeId       String
  teamId        String
  timeSlotStart DateTime
  timeSlotEnd   DateTime
  status        JudgeAssignmentStatus  @default(SCHEDULED)
  score         Float?
  judge         User                   @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  team          Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([judgeId, timeSlotStart])
}

model StallLocation {
  id          String @id @default(cuid())
  stallNumber Int    @unique
  building    String
  floor       Int
  x           Float
  y           Float
  z           Float  @default(0)
  teamId      String @unique
  team        Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model VolunteerZone {
  id          String @id @default(cuid())
  volunteerId String
  zoneName    String
  building    String
  floor       Int
  volunteer   User   @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
}
